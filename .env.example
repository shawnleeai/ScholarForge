# ScholarForge 环境配置示例
# 复制此文件为 .env 并填写实际值
# 警告：切勿将真实密码或密钥提交到 Git 仓库
#
# 安全提示：
# 1. 所有标记为"必填"的配置项必须在生产环境中设置
# 2. 使用强随机密钥（至少32字符）
# 3. 定期轮换密钥和密码
# 4. 使用环境变量或密钥管理服务存储敏感信息

# ============== 应用基础配置 ==============
APP_NAME=ScholarForge
APP_VERSION=0.1.0
DEBUG=false
SERVICE_NAME=scholarforge-service
SERVICE_PORT=8000
LOG_LEVEL=info

# ============== 数据库配置 (新ORM支持多数据库) ==============
# 数据库类型: postgresql / mysql / sqlite
DB_TYPE=postgresql
DB_HOST=localhost
DB_PORT=5432
DB_NAME=scholarforge
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_SSL_MODE=prefer
# DB_SSL_CA=/path/to/ca.crt

# 兼容旧配置
DATABASE_URL=postgresql://user:password@localhost:5432/scholarforge
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ============== Redis 配置 ==============
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# ============== JWT 配置（必填）=============
# 生成方式: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
# 或: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=your-jwt-secret-key-min-32-chars-use-random-generator
JWT_ALGORITHM=HS256
# 安全建议: 访问令牌1小时，刷新令牌7天
JWT_EXPIRE_HOURS=1
JWT_REFRESH_EXPIRE_DAYS=7

# ============== CORS 配置 ==============
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ============== 阿里云配置 (国内部署) ==============
ALIYUN_REGION=cn-hangzhou
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_DB_HOST=your-rds-id.pg.rds.aliyuncs.com
ALIYUN_DB_PORT=5432
ALIYUN_DB_NAME=scholarforge
ALIYUN_DB_USER=scholarforge
ALIYUN_DB_PASSWORD=
ALIYUN_REDIS_URL=rediss://:password@your-redis-id.redis.rds.aliyuncs.com:6379/0
ALIYUN_OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
ALIYUN_OSS_BUCKET=scholarforge-data

# ============== AWS配置 (国际部署) ==============
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DB_HOST=your-db.xxx.us-east-1.rds.amazonaws.com
AWS_DB_PORT=5432
AWS_DB_NAME=scholarforge
AWS_DB_USER=postgres
AWS_DB_PASSWORD=
AWS_REDIS_URL=rediss://xxx.cache.amazonaws.com:6379/0
AWS_S3_BUCKET=scholarforge-data-us-east-1

# ============== Elasticsearch 配置 ==============
ELASTICSEARCH_URL=http://localhost:9200

# ============== Qdrant (向量数据库) ==============
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ============== Neo4j 配置（必填）=============
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password

# ============== MinIO 配置（必填）=============
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=your-minio-access-key
MINIO_SECRET_KEY=your-minio-secret-key
MINIO_BUCKET=scholarforge
MINIO_SECURE=false

# ============== 学术数据库 API 配置 ==============
# CNKI API
CNKI_API_KEY=
CNKI_API_SECRET=

# Web of Science API
WOS_API_KEY=

# IEEE Xplore API
IEEE_API_KEY=

# Semantic Scholar
SEMANTIC_SCHOLAR_API_KEY=

# arXiv (无需API Key,但有限流)
ARXIV_RATE_LIMIT=3

# PubMed
NCBI_API_KEY=
NCBI_EMAIL=

# ============== AI 服务配置 ==============
# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4-turbo-preview

# Anthropic Claude
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-opus-20240229

# 国产大模型 - DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# 国产大模型 - Moonshot AI / Kimi
MOONSHOT_API_KEY=
MOONSHOT_MODEL=moonshot-v1-8k

# 国产大模型 - 阶跃星辰 / StepFun
STEPFUN_API_KEY=
STEPFUN_MODEL=step-1-8k
STEPFUN_BASE_URL=https://api.stepfun.com/v1

# 阿里云灵积
DASHSCOPE_API_KEY=

# Cohere (RAG重排序)
COHERE_API_KEY=

# AI默认设置
AI_DEFAULT_PROVIDER=stepfun
AI_FALLBACK_ENABLED=true

# ============== 推荐系统配置 ==============
# 每日推荐时间 (24小时制)
DAILY_RECOMMENDATION_HOUR=9
DAILY_RECOMMENDATION_MINUTE=0

# 推荐算法参数
RECOMMENDATION_CANDIDATES=100
RECOMMENDATION_TOP_K=10
RECOMMENDATION_MIN_SCORE=0.6

# ============== Celery 任务队列 ==============
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_WORKER_CONCURRENCY=4

# ============== 邮件配置 ==============
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@scholarforge.io
SMTP_PASSWORD=
SMTP_TLS=true

# ============== 前端配置 ==============
FRONTEND_URL=http://localhost:3000
FRONTEND_PORT=3000
API_URL=http://localhost:8000

# ============== Kong 网关配置 ==============
KONG_PROXY_PORT=8000
KONG_ADMIN_PORT=8001

# ============== 微服务端口配置 ==============
USER_SERVICE_PORT=8001
PAPER_SERVICE_PORT=8002
ARTICLE_SERVICE_PORT=8003
AI_SERVICE_PORT=8004
COLLAB_SERVICE_PORT=8005
RECOMMEND_SERVICE_PORT=8006

# ============== 监控与日志 ==============
SENTRY_DSN=
DATADOG_API_KEY=
