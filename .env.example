# ScholarForge 环境变量配置示例
# 复制此文件为 .env 并填写实际值
# 警告：切勿将真实密码或密钥提交到 Git 仓库

# ============== 应用基础配置 ==============
APP_NAME=ScholarForge
APP_VERSION=0.1.0
DEBUG=false
SERVICE_NAME=scholarforge-service
SERVICE_PORT=8000

# ============== 数据库配置 ==============
# 格式: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://user:password@localhost:5432/scholarforge
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ============== Redis 配置 ==============
REDIS_URL=redis://localhost:6379/0

# ============== JWT 配置（必填）=============
# 重要：请使用强密码生成器生成至少 32 位的随机字符串
# 示例: openssl rand -hex 32
JWT_SECRET=your-jwt-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24
JWT_REFRESH_EXPIRE_DAYS=7

# ============== CORS 配置 ==============
# 多个来源用逗号分隔
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ============== Elasticsearch 配置 ==============
ELASTICSEARCH_URL=http://localhost:9200

# ============== Neo4j 配置（必填）=============
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password

# ============== MinIO 配置（必填）=============
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=your-minio-access-key
MINIO_SECRET_KEY=your-minio-secret-key
MINIO_BUCKET=scholarforge
MINIO_SECURE=false

# ============== 学术数据库 API 配置（可选）=============
# CNKI API
CNKI_API_KEY=
CNKI_API_SECRET=

# Web of Science API
WOS_API_KEY=

# IEEE Xplore API
IEEE_API_KEY=

# ============== AI 服务配置（可选）=============
# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4-turbo-preview

# Anthropic Claude
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-opus-20240229

# ============== 前端配置 ==============
FRONTEND_PORT=3000

# ============== Kong 网关配置 ==============
KONG_PROXY_PORT=8000
KONG_ADMIN_PORT=8001

# ============== 微服务端口配置 ==============
USER_SERVICE_PORT=8001
PAPER_SERVICE_PORT=8002
ARTICLE_SERVICE_PORT=8003
AI_SERVICE_PORT=8004
COLLAB_SERVICE_PORT=8005
RECOMMEND_SERVICE_PORT=8006
